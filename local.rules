drop tcp any any -> any any (msg:"PORT SCAN detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 5; sid:1000001; rev:1;)

drop http any any -> any any (msg:"SQL Injection attempt"; content:"' OR 1=1"; nocase; http_uri; sid:1000002; rev:1;)
drop http any any -> any any (msg:"SQL Injection UNION SELECT"; content:"UNION SELECT"; nocase; http_uri; sid:1000003; rev:1;)
drop http any any -> any any (msg:"SQL Injection keyword SELECT"; content:"SELECT"; nocase; http_uri; sid:1000004; rev:1;)

drop http any any -> any any (msg:"XSS attempt script tag"; content:"<script>"; nocase; http_uri; sid:1000005; rev:1;)
drop http any any -> any any (msg:"XSS attempt alert()"; content:"alert("; nocase; http_uri; sid:1000006; rev:1;)
drop http any any -> any any (msg:"XSS encoded attempt"; content:"%3Cscript%3E"; nocase; http_uri; sid:1000007; rev:1;)
# port scan TCP

alert tcp any any -> $HOME_NET any (msg: "Portscan detected"; flags:S; detection_filter:track by_src, count 20, seconds 60; sid:1000001; rev:1;)

drop tcp any any -> $HOME_NET any (msg:"Blcoked TCP Portscan"; sid:1000002; rev:1;)

# SQL INJETCTION ATTACK

alert hhtp any any -> $HOME_NET any (msg:"SQL Injection attempt"; content:"`' OR '1'='1"; nocase; sid:1000003; rev:1;)

drop http any any -> $HOME_NET any(msg:"Blocked SQLi"; sid:1000004; rev:1;)

#XSS

alert http any any -> $HOME_NET any (msg:"XSS attempt"; content:"<script>"; nocase; sid:1000005; rev:1;)

drop http any any -> $HOME_NET any (msg:"Blocked XSS"; sid:1000006; rev:1;)



